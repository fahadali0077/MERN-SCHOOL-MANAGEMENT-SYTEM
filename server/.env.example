# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas: https://cloud.mongodb.com → Clusters → Connect → Driver
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/schoolms?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Upstash: https://console.upstash.com → Create Database → Copy "rediss://" URL
# Note: must start with rediss:// (TLS) not redis://
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# ─── Frontend URL (for CORS + email links) ───────────────────────────────────
CLIENT_URL=https://your-app.vercel.app

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────
# https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: enable 2FA → App Passwords → generate one
# Or use SendGrid: set SENDGRID_API_KEY instead (takes priority over SMTP_*)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_16chars
EMAIL_FROM=noreply@yourschool.com

# Optional — if using SendGrid instead of SMTP:
# SENDGRID_API_KEY=SG.xxxxx
